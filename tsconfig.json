{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      // "@assets": ["./src/assets"],
      // "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      // "@config": ["./src/config"],
      // "@data": ["./src/data"],
      // "@pages": ["./src/pages"],
      // "@theme": ["./src/theme"],
      // "@utils": ["./src/utils"],
      // "@graphql": ["./src/graphql"],
      // "@constants": path.resolve(__dirname, "./src/constants"),
      // "@hooks": path.resolve(__dirname, "./src/hooks"),
      // "@i18n": ["./src/i18n"],
      "@assets/*": ["./src/assets/*"],
      // "@config/*": ["./src/config/*"],
      "@data/*": ["./src/data/*"],
      // "@pages/*": ["./src/pages/*"],
      "@theme/*": ["./src/theme/*"],
      "@utils/*": ["./src/utils/*"],
      // "@constants": path.resolve(__dirname, "./src/constants"),
      // "@hooks": path.resolve(__dirname, "./src/hooks"),
      "@i18n/*": ["./src/i18n/*"],
      "@interfaces/*": ["./src/interfaces/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
