# Strapi Configuration
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_MEDIA_URL=http://localhost:1337
NEXT_PUBLIC_STRAPI_TOKEN=

# Network Configuration
# Timeout for API requests in milliseconds (default: 10000ms = 10 seconds)
NEXT_PUBLIC_API_TIMEOUT=10000
# Skeleton display timeout before showing network error (default: 5000ms = 5 seconds)
NEXT_PUBLIC_SKELETON_TIMEOUT=5000

# Logging Configuration
# Log levels: DEBUG, INFO, WARN, ERROR, NONE
# DEBUG - Show all logs (recommended for development)
# INFO - Show info, warn, and error logs
# WARN - Show only warnings and errors (recommended for production)
# ERROR - Show only errors
# NONE - Disable all logs
NEXT_PUBLIC_LOG_LEVEL=DEBUG
